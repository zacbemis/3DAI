# Copy to `.env` and fill in values. Never commit `.env`.

# --- Required for Gemini (OpenSCAD generation / modification) ---
GEMINI_API_KEY=

# --- Supabase (optional; enable DB-backed routes when set) ---
# Project URL from Supabase Dashboard → Settings → API
SUPABASE_URL=
# Server-side key: prefer the service role key here (never ship to the browser).
# This project reads `SUPABASE_SECRET` only.
SUPABASE_SECRET=

# --- Optional ---
# Public table used by some debug/list routes (default: `users`)
# SUPABASE_USER_TABLE=users

# Path to the OpenSCAD executable if `openscad` is not on PATH (e.g. custom install)
# OPENSCAD_PATH=/usr/bin/openscad
