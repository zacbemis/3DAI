# Copy to `.env` and fill in values. Never commit `.env`.

# --- AI Provider (set ONE of these; ANTHROPIC_API_KEY takes priority) ---
# Anthropic Claude
ANTHROPIC_API_KEY=
# Google Gemini (used when ANTHROPIC_API_KEY is not set)
GEMINI_API_KEY=

# --- Supabase (optional; enable DB-backed routes when set) ---
# Project URL from Supabase Dashboard → Settings → API
SUPABASE_URL=
# Server-side key — use the SERVICE ROLE key so inserts (e.g. `prompts`) are not blocked by RLS.
# Dashboard → Settings → API → service_role (secret). Never put this in the Electron app or commit it.
# If you only set the anon key, you will see: "new row violates row-level security policy for table \"prompts\"".
SUPABASE_SERVICE_ROLE_KEY=
# Legacy alias (same as service role if you prefer one env name):
# SUPABASE_SECRET=

# --- Optional ---
# Public table used by some debug/list routes (default: `users`)
# SUPABASE_USER_TABLE=users

# Path to the OpenSCAD executable if `openscad` is not on PATH (e.g. custom install)
# OPENSCAD_PATH=/Applications/OpenSCAD.app/Contents/MacOS/OpenSCAD
# Milliseconds for one STL export (CGAL can be slow). Default 600000 (10 min). Logs SIGKILL/SIGTERM if hit.
# OPENSCAD_TIMEOUT_MS=600000

# STL responses: default is **STL-only** — if OpenSCAD fails, API returns 503 JSON with stderr/stdout.
# Set to `true` to fall back to returning generated `.scad` as text (legacy behavior).
# MASTER_FALLBACK_TO_SCAD=true
