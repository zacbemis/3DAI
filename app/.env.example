# Supabase — get these from your project's Settings > API
# Put this file at `app/.env` (next to package.json). Vite does not read `.env` from `src/` unless
# you duplicate vars there — `vite.renderer.config.ts` merges `app/.env` + `app/src/.env`.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Used by ResetPassword to build the redirect link
VITE_SUPABASE_REDIRECT_TO=http://localhost:5173

# Master API (`services/master`) — generation + prompts insert
# Default: direct http://127.0.0.1:3000 (Electron dev disables webSecurity so fetch works).
# Optional: VITE_MASTER_USE_PROXY=true uses Vite `/master-api` proxy (see vite.renderer.config.ts)
# VITE_MASTER_API_URL=http://127.0.0.1:3000
# Optional if you do not use in-app project context (normally set via login + ProjectContext)
# VITE_MASTER_USER_ID=
# VITE_MASTER_PROJECT_ID=
